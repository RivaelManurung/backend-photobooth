# Server Configuration
PORT=8080
GIN_MODE=debug
FRONTEND_URL=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=photobooth
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Storage Configuration
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Supabase Storage Configuration (Optional)
SUPABASE_URL=https://your-project.supabase.co/storage/v1
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_BUCKET=photobooth

# GoPay QRIS Configuration (PRIMARY PAYMENT GATEWAY)
GOPAY_MERCHANT_ID=your-gopay-merchant-id
GOPAY_SECRET_KEY=your-gopay-secret-key
GOPAY_BASE_URL=https://api.gopay.co.id
GOPAY_CALLBACK_URL=http://localhost:8080/api/v1/webhooks/gopay
GOPAY_TERMINAL_ID=TERMINAL-001

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@photobooth.com
FROM_NAME=Photo Booth

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Legacy Payment Gateways (Optional - not used by default)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENV=sandbox
