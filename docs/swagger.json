{
  "swagger": "2.0",
  "info": {
    "title": "Photo Booth API",
    "description": "Complete REST API for Photo Booth Application with GoPay QRIS Payment Integration",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "email": "support@photobooth.com"
    }
  },
  "host": "localhost:8080",
  "basePath": "/api/v1",
  "schemes": ["http"],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your bearer token in the format: Bearer {token}"
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register new user",
        "description": "Create a new user account",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["name", "email", "password"],
              "properties": {
                "name": {"type": "string", "example": "John Doe"},
                "email": {"type": "string", "format": "email", "example": "john@example.com"},
                "password": {"type": "string", "minLength": 6, "example": "password123"},
                "phone": {"type": "string", "example": "+6281234567890"}
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User registered successfully",
            "schema": {
              "type": "object",
              "properties": {
                "access_token": {"type": "string"},
                "refresh_token": {"type": "string"},
                "user": {"$ref": "#/definitions/User"}
              }
            }
          },
          "400": {"description": "Invalid input"},
          "409": {"description": "Email already registered"}
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login user",
        "description": "Authenticate user and get access token",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email": {"type": "string", "format": "email", "example": "admin@photobooth.com"},
                "password": {"type": "string", "example": "admin123"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful",
            "schema": {
              "type": "object",
              "properties": {
                "access_token": {"type": "string"},
                "refresh_token": {"type": "string"},
                "user": {"$ref": "#/definitions/User"}
              }
            }
          },
          "401": {"description": "Invalid credentials"}
        }
      }
    },
    "/profile": {
      "get": {
        "tags": ["Profile"],
        "summary": "Get user profile",
        "security": [{"Bearer": []}],
        "responses": {
          "200": {
            "description": "Profile retrieved",
            "schema": {"$ref": "#/definitions/User"}
          },
          "401": {"description": "Unauthorized"}
        }
      },
      "put": {
        "tags": ["Profile"],
        "summary": "Update user profile",
        "security": [{"Bearer": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "phone": {"type": "string"},
                "avatar": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "200": {"description": "Profile updated"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/templates": {
      "get": {
        "tags": ["Templates"],
        "summary": "Get all templates",
        "parameters": [
          {"in": "query", "name": "category", "type": "string"},
          {"in": "query", "name": "is_active", "type": "boolean"},
          {"in": "query", "name": "search", "type": "string"}
        ],
        "responses": {
          "200": {
            "description": "Templates list",
            "schema": {
              "type": "object",
              "properties": {
                "templates": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/Template"}
                }
              }
            }
          }
        }
      }
    },
    "/templates/{id}": {
      "get": {
        "tags": ["Templates"],
        "summary": "Get single template",
        "parameters": [
          {"in": "path", "name": "id", "required": true, "type": "integer"}
        ],
        "responses": {
          "200": {
            "description": "Template details",
            "schema": {"$ref": "#/definitions/Template"}
          },
          "404": {"description": "Template not found"}
        }
      }
    },
    "/photos": {
      "get": {
        "tags": ["Photos"],
        "summary": "Get user photos",
        "security": [{"Bearer": []}],
        "responses": {
          "200": {
            "description": "Photos list",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Photo"}
            }
          }
        }
      },
      "post": {
        "tags": ["Photos"],
        "summary": "Upload photo",
        "security": [{"Bearer": []}],
        "consumes": ["multipart/form-data"],
        "parameters": [
          {"in": "formData", "name": "file", "type": "file", "required": true},
          {"in": "formData", "name": "template_id", "type": "integer", "required": true},
          {"in": "formData", "name": "session_id", "type": "integer"}
        ],
        "responses": {
          "201": {"description": "Photo uploaded"},
          "400": {"description": "Invalid input"}
        }
      }
    },
    "/payment/qris/create": {
      "post": {
        "tags": ["GoPay QRIS Payment"],
        "summary": "Create QRIS payment",
        "description": "Generate QR code for GoPay payment",
        "security": [{"Bearer": []}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["order_id", "amount"],
              "properties": {
                "order_id": {"type": "integer", "example": 1},
                "amount": {"type": "number", "format": "float", "example": 50000}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "QRIS payment created",
            "schema": {
              "type": "object",
              "properties": {
                "qr_code": {"type": "string", "description": "Base64 QR code image"},
                "qr_string": {"type": "string"},
                "payment_id": {"type": "string"},
                "expires_at": {"type": "string", "format": "date-time"}
              }
            }
          }
        }
      }
    },
    "/payment/qris/{order_id}/status": {
      "get": {
        "tags": ["GoPay QRIS Payment"],
        "summary": "Check payment status",
        "security": [{"Bearer": []}],
        "parameters": [
          {"in": "path", "name": "order_id", "required": true, "type": "integer"}
        ],
        "responses": {
          "200": {
            "description": "Payment status",
            "schema": {
              "type": "object",
              "properties": {
                "status": {"type": "string", "enum": ["pending", "paid", "expired", "cancelled"]},
                "paid_at": {"type": "string", "format": "date-time"}
              }
            }
          }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get user orders",
        "security": [{"Bearer": []}],
        "responses": {
          "200": {
            "description": "Orders list",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Order"}
            }
          }
        }
      }
    },
    "/admin/dashboard/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get dashboard statistics",
        "security": [{"Bearer": []}],
        "responses": {
          "200": {
            "description": "Dashboard stats",
            "schema": {
              "type": "object",
              "properties": {
                "total_users": {"type": "integer"},
                "active_users": {"type": "integer"},
                "total_photos": {"type": "integer"},
                "total_revenue": {"type": "number"}
              }
            }
          },
          "403": {"description": "Admin access required"}
        }
      }
    },
    "/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get all users",
        "security": [{"Bearer": []}],
        "parameters": [
          {"in": "query", "name": "page", "type": "integer", "default": 1},
          {"in": "query", "name": "limit", "type": "integer", "default": 20},
          {"in": "query", "name": "search", "type": "string"}
        ],
        "responses": {
          "200": {"description": "Users list"}
        }
      }
    }
  },
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "name": {"type": "string"},
        "email": {"type": "string"},
        "phone": {"type": "string"},
        "role": {"type": "string", "enum": ["user", "admin"]},
        "subscription_plan": {"type": "string", "enum": ["free", "basic", "premium"]},
        "is_active": {"type": "boolean"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "Template": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "name": {"type": "string"},
        "slug": {"type": "string"},
        "category": {"type": "string"},
        "description": {"type": "string"},
        "preview_url": {"type": "string"},
        "is_premium": {"type": "boolean"},
        "is_active": {"type": "boolean"},
        "usage_count": {"type": "integer"}
      }
    },
    "Photo": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "user_id": {"type": "integer"},
        "template_id": {"type": "integer"},
        "original_url": {"type": "string"},
        "processed_url": {"type": "string"},
        "status": {"type": "string", "enum": ["processing", "completed", "failed"]},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "Order": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "user_id": {"type": "integer"},
        "order_number": {"type": "string"},
        "total_amount": {"type": "number"},
        "status": {"type": "string", "enum": ["pending", "paid", "cancelled"]},
        "created_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
